{
  "expo": {
    "name": "bunqqq",
    "slug": "bunqqq",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSContactsUsageDescription": "Allow bunqqq to save Bunq as a contact so our texts and calls come through."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#07060B"
      },
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow bunqqq to save Bunq as a contact so our texts and calls come through."
        }
      ]
    ]
  }
}
